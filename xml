    <span class='institute-title'>THE_MORIBUND_INSTITUTE</span>
  </div>

  <button class='panel-toggle' data-target='panel-right'>[ Contents ]</button>
</div>

<div class='header-bottom-row'>
  <nav aria-label='Main navigation' class='terminal-nav'>
    <a href='/'>~/home</a>
    <a href='/p/about.html'>~/about</a>
    <a href='/p/projects.html'>~/projects</a>
    <a href='/p/contact.html'>~/contact</a>
    <a href='https://www.redbubble.com/people/WearYourWords/shop' rel='noopener' target='_blank'>~/merch</a>

    <!-- Added (no duplicates) -->
    <a href='/p/catalog.html'>~/catalog</a>
