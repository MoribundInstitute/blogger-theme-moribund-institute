              <b:widget-setting name='content'><![CDATA[<div id="terminal-toc-wrapper">
<div id="toc-loading" style="color: var(--fg-dim); animation: blink 1s infinite;">Building contents...</div>
  <ul id="terminal-toc-list" style="display:none; list-style: none; padding: 0; margin: 0;"></ul>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const container = document.getElementById('terminal-toc-list');
  const loading = document.getElementById('toc-loading');
  
  // Blogger injects post content inside .post-body
  const postBody = document.querySelector('.post-body');
  
  if (!postBody) {
    loading.innerText = "[SYS] WAITING FOR INPUT_STREAM...";
    loading.style.animation = "none";
    return;
  }

  // Find all headings within the post
  const headings = postBody.querySelectorAll('h2, h3, h4, h5');
  
  if (headings.length === 0) {
    loading.innerText = "[SYS] No anchor points found in document.";
    loading.style.animation = "none";
    return;
  }

  let html = '';
  headings.forEach((heading, index) => {
    // Ensure every heading has an ID so we can link to it
    if (!heading.id) {
      // Create a URL-safe ID from the heading text
      let safeText = heading.innerText.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
      heading.id = safeText ? safeText : 'section-' + index;
    }
    
    // Determine indentation based on heading level (H2 = 0 indent, H3 = 15px, etc)
    let level = parseInt(heading.tagName.substring(1));
    let indent = Math.max(0, (level - 2) * 15);
    
    // Format the prefix marker
    let marker = level === 2 ? '>' : '-';
    
    html += `<li style="margin-bottom: 8px; margin-left: ${indent}px; font-size: 0.85rem;">
               <a href="#${heading.id}" class="toc-jump-link" style="color: var(--fg-base); text-decoration: none; transition: color 0.1s;">
                 <span style="color: var(--fg-dim);">${marker}</span> ${heading.innerText}
               </a>
             </li>`;
  });

  container.innerHTML = html;
  loading.style.display = 'none';
  container.style.display = 'block';
});
</script>

<style>
@keyframes blink { 50% { opacity: 0; } }
.toc-jump-link:hover { 
  background: var(--fg-base); 
