<script>
(function () {
  async function load200Feed() {
    const container = document.getElementById("mor-200-feed");
    if (!container) return;

    const labels = [
      "200 Religion",
      "Religion",
      "Theology",
      "Biblical Studies",
      "Christianity",
      "Judaism",
      "Islam",
      "Buddhism",
      "Hinduism",
      "Mythology",
      "Comparative Religion",
      "Church History",
      "Religious Language",
      "Angelology",
      "Christology",
      "Two Powers In Heaven",
      "Scripture Study",
      "Sacred Vocabulary"
    ];

    const seen = new Set();
    const posts = [];

    try {
      for (const label of labels) {
        const url = "/feeds/posts/summary/-/" + encodeURIComponent(label) + "?alt=json&max-results=8";
        const response = await fetch(url);
        if (!response.ok) continue;

        const data = await response.json();
        const entries = data.feed && data.feed.entry ? data.feed.entry : [];

        entries.forEach(entry => {
          const title = entry.title && entry.title.$t ? entry.title.$t : "Untitled Post";
          const link = entry.link.find(item => item.rel === "alternate");
          const href = link ? link.href : "#";
          const published = entry.published && entry.published.$t ? entry.published.$t : "";

          if (!seen.has(href)) {
            seen.add(href);
            posts.push({
              title,
              href,
              timestamp: published ? new Date(published).getTime() : 0
            });
          }
        });
      }

      posts.sort((a, b) => b.timestamp - a.timestamp);

      if (!posts.length) {
        container.innerHTML = '<div class="mor-feed-status">No 200 entries found yet. Add labels such as “200 Religion”, “Theology”, “Biblical Studies”, or “Christianity” to posts.</div>';
        return;
      }

      container.innerHTML = "";

      posts.slice(0, 12).forEach(post => {
        const a = document.createElement("a");
        a.href = post.href;
        a.textContent = post.title;
        container.appendChild(a);
      });
    } catch (error) {
      container.innerHTML = '<div class="mor-feed-status">Could not load the 200 feed. Check Blogger feed visibility and labels.</div>';
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", load200Feed);
  } else {
    load200Feed();
  }
})();
</script>
